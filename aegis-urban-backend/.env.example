# ── Copiar este archivo como .env y completar los valores ──

# Servidor
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Base de Datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aegis_urban_db
DB_USER=aegis_app_user
DB_PASSWORD=aegis_secure_pass_2026
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONN_TIMEOUT=5000

# JWT (Sprint 2) — generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZAR_CON_STRING_ALEATORIO_DE_64_CHARS
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# AES-256-CBC (Sprint 2) — la clave DEBE ser exactamente 64 caracteres hex (= 32 bytes)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_SECRET_KEY=REEMPLAZAR_CON_64_CHARS_HEX
